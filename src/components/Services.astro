---
const services = [
  {
    id: 'social',
    num: '01',
    title: 'Social Media Management',
    description: 'We build and execute tailored monthly strategies across your key platforms — keeping your brand visible, your audience engaged, and your growth on track.',
    features: [
      'Custom content calendars',
      'Instagram, Facebook & more',
      'Monthly performance reports',
      'Community engagement',
      'Paid ad support',
    ],
    color: '#06b6d4',
    glow: 'rgba(6,182,212,0.12)',
    icon: 'social',
  },
  {
    id: 'web',
    num: '02',
    title: 'Website Development',
    description: 'From sleek portfolio sites to full e-commerce platforms, we craft fast, modern websites that look great and turn visitors into customers.',
    features: [
      'Custom design & development',
      'Mobile-first & responsive',
      'SEO-optimized structure',
      'Speed & Core Web Vitals',
      'Ongoing maintenance',
    ],
    color: '#f59e0b',
    glow: 'rgba(245,158,11,0.12)',
    icon: 'web',
  },
  {
    id: 'content',
    num: '03',
    title: 'Content Creation',
    description: 'Professional photo and video content that captures your brand story and stops the scroll — created specifically for your audience and platform.',
    features: [
      'Brand photography & video',
      'Reels & short-form content',
      'Product & event shoots',
      'Scripted & edited posts',
      'Cross-platform formatting',
    ],
    color: '#10b981',
    glow: 'rgba(16,185,129,0.12)',
    icon: 'content',
  },
];
---

<section id="services" class="services-section">
  <div class="section-bg" aria-hidden="true"></div>

  <div class="container">
    <div class="section-header" data-reveal>
      <span class="section-label">What We Do</span>
      <h2>Services Built for Growth</h2>
      <p>Everything you need to dominate your corner of the internet — done for you, by a bilingual team that understands your market.</p>
    </div>

    <div class="services-grid">
      {services.map((s, i) => (
        <article
          class="service-card"
          style={`--card-color: ${s.color}; --card-glow: ${s.glow};`}
          data-reveal
          data-reveal-delay={String(i + 1)}
        >
          <div class="card-num" aria-hidden="true">{s.num}</div>

          <div class="card-icon-wrap">
            {s.icon === 'social' && (
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
                <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
                <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
              </svg>
            )}
            {s.icon === 'web' && (
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="3" width="20" height="14" rx="2"/>
                <line x1="8" y1="21" x2="16" y2="21"/>
                <line x1="12" y1="17" x2="12" y2="21"/>
              </svg>
            )}
            {s.icon === 'content' && (
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polygon points="23 7 16 12 23 17 23 7"/>
                <rect x="1" y="5" width="15" height="14" rx="2"/>
              </svg>
            )}
          </div>

          <h3 class="card-title">{s.title}</h3>
          <p class="card-desc">{s.description}</p>

          <ul class="card-features" aria-label={`${s.title} features`}>
            {s.features.map(f => (
              <li>
                <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
                  <circle cx="6.5" cy="6.5" r="5.75" stroke="currentColor" stroke-width="1.2"/>
                  <path d="M4 6.5l1.75 1.75L9.5 5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {f}
              </li>
            ))}
          </ul>

          <a href="#contact" class="card-cta" aria-label={`Get started with ${s.title}`}>
            Get Started
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M2.5 7h9M8 3.5L11.5 7 8 10.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </article>
      ))}
    </div>

    <p class="services-note" data-reveal>
      Not sure which service you need?
      <a href="#contact">Let's talk — we'll figure it out together. →</a>
    </p>
  </div>
</section>

<style>
  .services-section {
    padding: var(--section-pad);
    background: #09091a;
    position: relative;
    overflow: hidden;
  }

  .section-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 40% at 50% 0%, rgba(6,182,212,0.05) 0%, transparent 70%),
      radial-gradient(ellipse 40% 50% at 100% 50%, rgba(245,158,11,0.04) 0%, transparent 70%);
    pointer-events: none;
  }

  .container {
    max-width: var(--max-w);
    margin: 0 auto;
    position: relative;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .service-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 2.25rem;
    display: flex;
    flex-direction: column;
    gap: 0;
    position: relative;
    overflow: hidden;
    transition: border-color 0.35s, transform 0.35s cubic-bezier(0.22,1,0.36,1), box-shadow 0.35s;
  }

  .service-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--card-color), transparent 80%);
    opacity: 0;
    transition: opacity 0.35s;
  }

  .service-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 0% 0%, var(--card-glow) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.4s;
    pointer-events: none;
  }

  .service-card:hover {
    border-color: color-mix(in srgb, var(--card-color) 40%, transparent);
    transform: translateY(-8px);
    box-shadow: 0 24px 64px rgba(0,0,0,0.4), 0 4px 24px rgba(0,0,0,0.2);
  }

  .service-card:hover::before,
  .service-card:hover::after { opacity: 1; }

  .card-num {
    position: absolute;
    top: 2rem; right: 2rem;
    font-family: var(--font-display);
    font-size: 3.5rem;
    font-weight: 800;
    color: var(--card-color);
    opacity: 0.06;
    line-height: 1;
    letter-spacing: -0.04em;
    user-select: none;
    transition: opacity 0.3s;
  }

  .service-card:hover .card-num { opacity: 0.12; }

  .card-icon-wrap {
    width: 54px; height: 54px;
    background: var(--card-glow);
    border: 1px solid color-mix(in srgb, var(--card-color) 25%, transparent);
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--card-color);
    margin-bottom: 1.5rem;
    position: relative;
    z-index: 1;
    transition: transform 0.3s cubic-bezier(0.22,1,0.36,1), box-shadow 0.3s;
    flex-shrink: 0;
  }

  .service-card:hover .card-icon-wrap {
    transform: scale(1.1) rotate(-4deg);
    box-shadow: 0 8px 28px var(--card-glow);
  }

  .card-title {
    font-size: 1.3rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 0.875rem;
    position: relative;
    z-index: 1;
  }

  .card-desc {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.75;
    margin-bottom: 1.5rem;
    position: relative;
    z-index: 1;
  }

  .card-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-bottom: 2rem;
    flex: 1;
    position: relative;
    z-index: 1;
  }

  .card-features li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.855rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  .card-features li svg {
    color: var(--card-color);
    flex-shrink: 0;
  }

  .card-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--card-color);
    font-size: 0.875rem;
    font-weight: 700;
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: gap 0.25s;
    border-top: 1px solid var(--border);
    padding-top: 1.25rem;
    margin-top: auto;
    position: relative;
    z-index: 1;
  }

  .card-cta:hover { gap: 0.875rem; }

  .services-note {
    text-align: center;
    color: var(--text-subtle);
    font-size: 0.9rem;
    margin-top: 3.5rem;
  }

  .services-note a {
    color: var(--accent);
    font-weight: 600;
    text-decoration: none;
    transition: color 0.2s;
  }

  .services-note a:hover { color: #22d3ee; }

  @media (max-width: 960px) {
    .services-grid {
      grid-template-columns: 1fr;
      max-width: 500px;
      margin: 0 auto;
    }
  }

  @media (min-width: 600px) and (max-width: 960px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
      max-width: none;
    }
  }
</style>
