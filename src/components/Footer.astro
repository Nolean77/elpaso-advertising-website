tion---
const year = new Date().getFullYear();

const footerLinks = [
  { label: 'Services',     href: '#services'     },
  { label: 'Portfolio',    href: '#portfolio'    },
  { label: 'Team',         href: '#team'         },
  { label: 'Testimonials', href: '#testimonials' },
  { label: 'Contact',      href: '#contact'      },
];

const services = [
  { label: 'Social Media Management', href: '#services' },
  { label: 'Website Development',     href: '#services' },
  { label: 'Content Creation',        href: '#services' },
];
---

<footer class="site-footer">
  <!-- Gradient divider -->
  <div class="footer-divider" aria-hidden="true">
    <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
      <path d="M0 80 C360 10 1080 10 1440 80 L1440 0 L0 0 Z" fill="#09091a"/>
    </svg>
  </div>

  <!-- Glow accent -->
  <div class="footer-glow" aria-hidden="true"></div>

  <div class="footer-inner">
    <div class="footer-grid">

      <!-- ── Brand column ── -->
      <div class="footer-brand">
        <a href="/" class="footer-logo" aria-label="El Paso Advertising Solutions home">
          <div class="logo-mark" aria-hidden="true">
            <svg width="30" height="30" viewBox="0 0 32 32" fill="none">
              <rect width="32" height="32" rx="8" fill="rgba(6,182,212,0.12)"/>
              <rect x="1" y="1" width="30" height="30" rx="7" stroke="rgba(6,182,212,0.3)" stroke-width="1"/>
              <text x="50%" y="54%" dominant-baseline="middle" text-anchor="middle"
                font-family="'Bricolage Grotesque', sans-serif"
                font-size="12" font-weight="800" fill="#06b6d4" letter-spacing="-0.5">EP</text>
            </svg>
          </div>
          <span class="logo-wordmark">
            <span class="logo-ep">EP</span> Advertising Solutions
          </span>
        </a>

        <p class="brand-tagline">
          A bilingual digital marketing team helping businesses grow online — across the US, Mexico, and Latin America.
        </p>

        <div class="footer-social">
          <a href="https://www.facebook.com/profile.php?id=61551683397738" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="Follow us on Facebook">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
            </svg>
          </a>
          <a href="https://www.instagram.com/elpasoadvertisingsolutions" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="Follow us on Instagram">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>
        </div>

        <!-- Bilingual indicator -->
        <div class="footer-lang">
          <span>🇺🇸 English</span>
          <span class="lang-sep">·</span>
          <span>🇲🇽 Español</span>
        </div>
      </div>

      <!-- ── Nav column ── -->
      <nav class="footer-col" aria-label="Footer navigation">
        <h3 class="col-heading">Navigate</h3>
        <ul role="list">
          {footerLinks.map(link => (
            <li><a href={link.href} class="footer-link">{link.label}</a></li>
          ))}
        </ul>
      </nav>

      <!-- ── Services column ── -->
      <div class="footer-col">
        <h3 class="col-heading">Services</h3>
        <ul role="list">
          {services.map(s => (
            <li><a href={s.href} class="footer-link">{s.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- ── Contact column ── -->
      <div class="footer-col">
        <h3 class="col-heading">Contact</h3>
        <ul class="contact-list" role="list">
          <li>
            <a href="https://wa.me/+526563882009" target="_blank" rel="noopener noreferrer" class="footer-link contact-item">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              WhatsApp Us
            </a>
          </li>
          <li>
            <a href="mailto:carlosterrazask@gmail.com" class="footer-link contact-item">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="4" width="20" height="16" rx="2"/>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 01-2.06 0L2 7"/>
              </svg>
              carlosterrazask@gmail.com
            </a>
          </li>
          <li class="contact-item location-item">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0118 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            El Paso, TX · Austin, TX · Latin America
          </li>
        </ul>

        <a href="#contact" class="footer-cta">
          Start a Project →
        </a>
      </div>
    </div>

    <!-- ── Bottom bar ── -->
    <div class="footer-bottom">
      <p class="copyright">
        © {year} El Paso Advertising Solutions. All rights reserved.
      </p>
      <p class="built-by">
        Designed &amp; built with ❤️ in El Paso, TX 🤘
      </p>
    </div>
    <!-- ── Legal row ── -->
    <div class="footer-legal">
      <a href="/privacy" class="legal-link">Privacy Policy</a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: #050810;
    color: var(--text-muted);
    position: relative;
  }

  /* Divider */
  .footer-divider {
    height: 80px;
    overflow: hidden;
    line-height: 0;
    margin-bottom: -1px;
  }

  .footer-divider svg {
    width: 100%; height: 100%;
    display: block;
  }

  /* Ambient glow */
  .footer-glow {
    position: absolute;
    top: 80px;
    left: 50%;
    transform: translateX(-50%);
    width: 600px; height: 200px;
    background: radial-gradient(ellipse, rgba(6,182,212,0.06) 0%, transparent 70%);
    pointer-events: none;
    filter: blur(40px);
  }

  .footer-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 4rem 1.5rem 2.5rem;
    position: relative;
  }

  /* ── Grid ── */
  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1.4fr;
    gap: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    margin-bottom: 2rem;
  }

  /* ── Brand ── */
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .footer-logo:hover { opacity: 0.8; }

  .logo-wordmark {
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 700;
    color: #e2e8f0;
    letter-spacing: -0.02em;
  }

  .logo-ep { color: var(--accent); }

  .brand-tagline {
    font-size: 0.85rem;
    line-height: 1.7;
    color: var(--text-subtle);
    max-width: 280px;
  }

  .footer-social {
    display: flex;
    gap: 0.6rem;
  }

  .social-icon {
    width: 36px; height: 36px;
    border-radius: 8px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-subtle);
    text-decoration: none;
    transition: color 0.2s, border-color 0.2s, background 0.2s, transform 0.2s;
  }

  .social-icon:hover {
    color: var(--accent);
    border-color: rgba(6,182,212,0.35);
    background: rgba(6,182,212,0.07);
    transform: translateY(-2px);
  }

  .footer-lang {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    color: var(--text-subtle);
    font-weight: 500;
  }

  .lang-sep { opacity: 0.4; }

  /* ── Cols ── */
  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .col-heading {
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 700;
    color: #e2e8f0;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.6rem;
  }

  .footer-col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
  }

  .footer-link {
    display: inline-block;
    font-size: 0.85rem;
    color: var(--text-subtle);
    text-decoration: none;
    padding: 0.3rem 0;
    transition: color 0.2s;
  }

  .footer-link:hover { color: var(--accent); }

  /* Contact list */
  .contact-list { margin-bottom: 1.25rem; }

  .contact-item {
    display: flex !important;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.82rem !important;
    line-height: 1.5;
  }

  .contact-item svg {
    flex-shrink: 0;
    margin-top: 2px;
    color: var(--text-subtle);
  }

  .location-item {
    color: var(--text-subtle);
    cursor: default;
  }

  .location-item:hover { color: var(--text-subtle) !important; }

  /* Footer CTA */
  .footer-cta {
    display: inline-block;
    background: var(--amber);
    color: #07080f;
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 700;
    padding: 0.6rem 1.25rem;
    border-radius: 8px;
    text-decoration: none;
    letter-spacing: 0.01em;
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
    margin-top: 0.25rem;
    align-self: flex-start;
  }

  .footer-cta:hover {
    background: #fbbf24;
    transform: translateY(-1px);
    box-shadow: 0 4px 18px rgba(245,158,11,0.35);
  }

  /* ── Bottom bar ── */
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .copyright, .built-by {
    font-size: 0.78rem;
    color: var(--text-subtle);
  }

  /* ── Legal row ── */
  .footer-legal {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255,255,255,0.04);
    display: flex;
    gap: 1.5rem;
  }

  .legal-link {
    font-size: 0.75rem;
    color: var(--text-subtle);
    text-decoration: none;
    transition: color 0.2s;
  }

  .legal-link:hover { color: var(--accent); }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
    .footer-brand { grid-column: span 2; }
  }

  @media (max-width: 520px) {
    .footer-grid { grid-template-columns: 1fr; }
    .footer-brand { grid-column: span 1; }
    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
