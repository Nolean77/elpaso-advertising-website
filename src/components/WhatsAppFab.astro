---
const whatsappUrl = 'https://wa.me/+526563882009';
const label = 'Chat with us on WhatsApp';
---

<a
  href={whatsappUrl}
  target="_blank"
  rel="noopener noreferrer"
  class="whatsapp-fab"
  aria-label={label}
>
  <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path
      d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
    />
  </svg>
  <span class="fab-label">WhatsApp</span>
</a>

<style>
  .whatsapp-fab {
    position: fixed;
    right: 1.5rem;
    bottom: 1.5rem;
    z-index: 9999;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    background: #25d366;
    color: #fff;
    padding: 0.78rem 1.25rem 0.78rem 1rem;
    border-radius: 999px;
    font-family: var(--font-body, 'Plus Jakarta Sans', sans-serif);
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    text-decoration: none;
    box-shadow: 0 4px 24px rgba(37, 211, 102, 0.45), 0 2px 12px rgba(0, 0, 0, 0.35);
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.25s, background 0.2s;
    isolation: isolate;
  }

  .whatsapp-fab:hover {
    background: #20c05c;
    transform: translateY(-3px) scale(1.03);
    box-shadow: 0 10px 32px rgba(37, 211, 102, 0.55), 0 6px 16px rgba(0, 0, 0, 0.3);
  }

  .whatsapp-fab:active {
    transform: translateY(0) scale(0.98);
  }

  .whatsapp-fab:focus-visible {
    outline: 3px solid rgba(37, 211, 102, 0.6);
    outline-offset: 4px;
  }

  .whatsapp-fab::before {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: inherit;
    border: 2px solid rgba(37, 211, 102, 0.35);
    animation: fabPulse 2.5s ease infinite;
    pointer-events: none;
    z-index: -1;
  }

  .fab-label {
    white-space: nowrap;
  }

  @keyframes fabPulse {
    0%,
    100% {
      opacity: 0.6;
      transform: scale(1);
    }
    50% {
      opacity: 0;
      transform: scale(1.15);
    }
  }

  @media (max-width: 640px) {
    .whatsapp-fab {
      right: 1.1rem;
      bottom: 1.1rem;
      padding: 0.85rem;
    }
  }

  @media (max-width: 520px) {
    .whatsapp-fab {
      width: 58px;
      height: 58px;
      justify-content: center;
      gap: 0;
      border-radius: 999px;
    }

    .fab-label {
      display: none;
    }
  }

  @supports (padding: max(0px)) {
    .whatsapp-fab {
      padding-bottom: max(0.85rem, env(safe-area-inset-bottom, 0px));
    }
  }
</style>