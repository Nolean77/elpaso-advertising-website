---
import { LINKS } from '../data/site';

const whatsappUrl = LINKS.whatsapp;
const label = 'Chat with us on WhatsApp';
---

<a
 href={whatsappUrl}
 target="_blank"
 rel="noopener noreferrer"
 class="whatsapp-fab"
 aria-label={label}
>
 <span class="fab-icon" aria-hidden="true">💬</span>
 <span class="fab-label">WhatsApp</span>
</a>

<style>
 .whatsapp-fab {
 position: fixed;
 right: max(0.85rem, env(safe-area-inset-right, 0px));
 bottom: calc(0.85rem + env(safe-area-inset-bottom, 0px));
 left: auto;
 z-index: 9999;
 display: inline-flex;
 align-items: center;
 gap: 0.5rem;
 width: fit-content;
 max-width: calc(100dvw - 1.7rem - env(safe-area-inset-right, 0px));
 background: #25d366;
 color: #fff;
 padding: 0.78rem 1.1rem 0.78rem 0.85rem;
 border-radius: 999px;
 font-family: var(--font-body, 'Plus Jakarta Sans', sans-serif);
 font-size: 0.9rem;
 font-weight: 700;
 letter-spacing: 0.01em;
 text-decoration: none;
 white-space: nowrap;
 box-shadow: 0 4px 24px rgba(37, 211, 102, 0.45), 0 2px 12px rgba(0, 0, 0, 0.35);
 transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.25s, background 0.2s;
 isolation: isolate;
 }

 .whatsapp-fab:hover {
 background: #20c05c;
 transform: translateY(-3px) scale(1.03);
 box-shadow: 0 10px 32px rgba(37, 211, 102, 0.55), 0 6px 16px rgba(0, 0, 0, 0.3);
 }

 .whatsapp-fab:active {
 transform: translateY(0) scale(0.98);
 }

 .whatsapp-fab:focus-visible {
 outline: 3px solid rgba(37, 211, 102, 0.6);
 outline-offset: 4px;
 }

 .whatsapp-fab::before {
 content: '';
 position: absolute;
 inset: -4px;
 border-radius: inherit;
 border: 2px solid rgba(37, 211, 102, 0.35);
 animation: fabPulse 2.5s ease infinite;
 pointer-events: none;
 z-index: -1;
 }

 .fab-icon {
 display: inline-flex;
 align-items: center;
 justify-content: center;
 width: 1.8rem;
 height: 1.8rem;
 border-radius: 999px;
 background: rgba(255,255,255,0.16);
 font-size: 0.95rem;
 line-height: 1;
 }

 .fab-label {
 white-space: nowrap;
 }

 @keyframes fabPulse {
 0%,
 100% {
 opacity: 0.6;
 transform: scale(1);
 }

 50% {
 opacity: 0;
 transform: scale(1.15);
 }
 }

 @media (min-width:641px) {
 .whatsapp-fab {
 right: max(1rem, env(safe-area-inset-right, 0px));
 bottom: calc(1rem + env(safe-area-inset-bottom, 0px));
 max-width: calc(100dvw - 2rem - env(safe-area-inset-right, 0px));
 }
 }

 @media (max-width:520px) {
 .whatsapp-fab {
 width: 56px;
 height: 56px;
 min-width: 56px;
 justify-content: center;
 gap: 0;
 padding: 0;
 border-radius: 999px;
 }

 .fab-label {
 display: none;
 }
 }
</style>