---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, author, authorTitle, featuredImage, featuredImageAlt, tags, language } = post.data;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const langLabel = language === 'es' ? 'ES' : 'EN';
const postUrl = `/blog/${post.id}`;
---

<article class="blog-card" data-lang={language}>
  <a href={postUrl} class="card-image-link" aria-label={`Read: ${title}`}>
    {featuredImage ? (
      <img
        src={featuredImage}
        alt={featuredImageAlt ?? title}
        class="card-image"
        loading="lazy"
        decoding="async"
        width="600"
        height="340"
      />
    ) : (
      <div class="card-image-placeholder" aria-hidden="true">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
          <rect x="3" y="3" width="18" height="18" rx="3"/>
          <path d="M3 9h18M9 21V9"/>
        </svg>
      </div>
    )}
    <span class={`lang-badge lang-${language}`}>{langLabel}</span>
  </a>

  <div class="card-body">
    {tags.length > 0 && (
      <div class="card-tags">
        {tags.map(tag => (
          <a href={`/blog/tag/${tag}`} class="tag-chip">{tag}</a>
        ))}
      </div>
    )}

    <h3 class="card-title">
      <a href={postUrl}>{title}</a>
    </h3>

    <p class="card-description">{description}</p>

    <div class="card-meta">
      <div class="card-author">
        <div class="author-avatar" aria-hidden="true">{author.charAt(0)}</div>
        <div>
          <span class="author-name">{author}</span>
          {authorTitle && <span class="author-title">{authorTitle}</span>}
        </div>
      </div>
      <time class="card-date" datetime={pubDate.toISOString()}>{formattedDate}</time>
    </div>

    <a href={postUrl} class="card-read-more" aria-label={`Read full post: ${title}`}>
      Read More <span aria-hidden="true">→</span>
    </a>
  </div>
</article>

<style>
  .blog-card {
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }

  .blog-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(108, 99, 255, 0.18);
    border-color: rgba(108, 99, 255, 0.4);
  }

  /* ── Image ── */
  .card-image-link {
    display: block;
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    flex-shrink: 0;
    text-decoration: none;
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .blog-card:hover .card-image {
    transform: scale(1.04);
  }

  .card-image-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #1a1a3e 0%, #0d0d1a 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(108, 99, 255, 0.35);
  }

  /* ── Language badge ── */
  .lang-badge {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.2rem 0.55rem;
    border-radius: 6px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .lang-en {
    background: rgba(108, 99, 255, 0.85);
    color: #fff;
  }

  .lang-es {
    background: rgba(255, 101, 132, 0.85);
    color: #fff;
  }

  /* ── Body ── */
  .card-body {
    padding: 1.4rem 1.5rem 1.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    flex: 1;
  }

  /* ── Tags ── */
  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag-chip {
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--accent);
    background: rgba(108, 99, 255, 0.1);
    border: 1px solid rgba(108, 99, 255, 0.2);
    padding: 0.2rem 0.6rem;
    border-radius: 100px;
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
    letter-spacing: 0.02em;
  }

  .tag-chip:hover {
    background: rgba(108, 99, 255, 0.22);
    color: #a9a3ff;
  }

  /* ── Title ── */
  .card-title {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: -0.02em;
    color: var(--text);
  }

  .card-title a {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s;
  }

  .card-title a:hover {
    color: var(--accent);
  }

  /* ── Description ── */
  .card-description {
    font-size: 0.88rem;
    color: var(--text-muted);
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Meta ── */
  .card-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 0.4rem;
    border-top: 1px solid var(--border);
    gap: 0.75rem;
  }

  .card-author {
    display: flex;
    align-items: center;
    gap: 0.55rem;
  }

  .author-avatar {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: rgba(108, 99, 255, 0.2);
    border: 1px solid rgba(108, 99, 255, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--accent);
    flex-shrink: 0;
  }

  .author-name {
    display: block;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text);
    line-height: 1.2;
  }

  .author-title {
    display: block;
    font-size: 0.72rem;
    color: var(--text-muted);
    line-height: 1.2;
  }

  .card-date {
    font-size: 0.75rem;
    color: var(--text-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ── Read More ── */
  .card-read-more {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    transition: gap 0.2s, color 0.2s;
    margin-top: 0.25rem;
  }

  .card-read-more:hover {
    gap: 0.6rem;
    color: #a9a3ff;
  }
</style>
