---
import { Image } from 'astro:assets';
import futureStrike from '../assets/portfolio/future-strike.jpg';
import pawsInHeaven from '../assets/portfolio/paws-in-heaven.jpg';
import polloRico from '../assets/portfolio/pollo-rico.jpg';
import pulmonaryHealth from '../assets/portfolio/pulmonary-health.png';
import rvPark from '../assets/portfolio/rv-park.jpg';
import solafire from '../assets/portfolio/solafire.jpg';
import topRvParts from '../assets/portfolio/top-rv-parts.jpg';
import openDoorsLegal from '../assets/portfolio/open-doors-legal.avif';

const portfolioItems = [
  {
    title: 'Future Strike',
    category: 'Facebook & Social Media Marketing',
    image: futureStrike,
    color: '#06b6d4',
    links: {
      facebook: 'https://www.facebook.com/FutureStrike',
    },
  },
  {
    title: 'Paws in Heaven',
    category: 'Social Media Management',
    image: pawsInHeaven,
    color: '#f59e0b',
    links: {
      facebook: 'https://www.facebook.com/PawsInHeavenEP',
      website: 'https://pawsinheaven.com',
    },
  },
  {
    title: 'Pollo Rico',
    category: 'Social Media & Branding',
    image: polloRico,
    color: '#10b981',
    links: {
      facebook: 'https://www.facebook.com/PolloRicoEP',
      website: 'https://www.pollosricos.com/',
    },
  },
  {
    title: 'Pulmonary Health Center',
    category: 'Healthcare Marketing',
    image: pulmonaryHealth,
    color: '#8b5cf6',
    links: {
      facebook: 'https://www.facebook.com/PulmonaryHealthCenter',
      website: 'https://pulmonaryhealthcenter.com',
    },
  },
  {
    title: 'RV Park',
    category: 'Hospitality & Tourism',
    image: rvPark,
    color: '#ec4899',
    links: {
      facebook: 'https://www.facebook.com/p/El-Paso-Roadrunner-RV-Park-61573168067817/',
      website: 'https://www.elpasoroadrunnerrv.com/',
    },
  },
  {
    title: 'Solafire',
    category: 'Research & Science Communication',
    image: solafire,
    color: '#f97316',
    links: {
      facebook: 'https://www.facebook.com/Solafire',
      website: 'https://www.solafire.org/',
    },
  },
  {
    title: 'Top RV Parts',
    category: 'E-Commerce Development',
    image: topRvParts,
    color: '#14b8a6',
    links: {
      facebook: 'https://www.facebook.com/TopRVParts/',
      website: 'https://shop.toprvparts.com/',
    },
  },
  {
    title: 'Open Doors Legal',
    category: 'Website Development',
    image: openDoorsLegal,
    color: '#6366f1',
    links: {
      website: 'https://www.opendoorslegal.com/',
    },
  },
];
---

<section id="portfolio" class="portfolio-section">
  <div class="section-bg" aria-hidden="true"></div>

  <div class="container">
    <div class="section-header" data-reveal>
      <span class="section-label">Our Work</span>
      <h2>Trusted by Businesses Across Industries</h2>
      <p>From restaurants to healthcare, e-commerce to hospitality — we deliver results that matter.</p>
    </div>

    <div class="portfolio-grid">
      {portfolioItems.map((item, i) => (
        <article
          class="portfolio-card"
          style={`--card-color: ${item.color};`}
          data-reveal
          data-reveal-delay={String((i % 3) + 1)}
        >
          <div class="card-image">
            <Image
              src={item.image}
              alt={`${item.title} - ${item.category} project by El Paso Advertising Solutions`}
              width={600}
              height={400}
              loading={i < 3 ? 'eager' : 'lazy'}
              format="webp"
              quality={85}
            />
            <div class="card-overlay">
              <div class="overlay-content">
                <span class="overlay-category">{item.category}</span>
                <h3 class="overlay-title">{item.title}</h3>
                {Object.keys(item.links).length > 0 && (
                  <div class="overlay-links">
                    {item.links.facebook && (
                      <a href={item.links.facebook} target="_blank" rel="noopener noreferrer" class="link-btn" aria-label={`${item.title} Facebook`}>
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                          <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                        </svg>
                      </a>
                    )}
                    {item.links.website && (
                      <a href={item.links.website} target="_blank" rel="noopener noreferrer" class="link-btn" aria-label={`${item.title} Website`}>
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <circle cx="12" cy="12" r="10"/>
                          <line x1="2" y1="12" x2="22" y2="12"/>
                          <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
                        </svg>
                      </a>
                    )}
                  </div>
                )}
                <a href="#contact" class="overlay-cta">
                  Get Similar Results
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                    <path d="M2.5 7h9M8 3.5L11.5 7 8 10.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="portfolio-cta" data-reveal>
      <p>Want to see your business here?</p>
      <a href="#contact" class="btn-primary">
        Start Your Project
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .portfolio-section {
    padding: var(--section-pad);
    background: #0a0b1a;
    position: relative;
    overflow: hidden;
  }

  .section-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 50% 50% at 20% 30%, rgba(6,182,212,0.04) 0%, transparent 70%),
      radial-gradient(ellipse 50% 50% at 80% 70%, rgba(245,158,11,0.04) 0%, transparent 70%);
    pointer-events: none;
  }

  .container {
    max-width: var(--max-w);
    margin: 0 auto;
    position: relative;
  }

  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 4rem;
  }

  .portfolio-card {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--bg-card);
    border: 1px solid var(--border);
    transition: border-color 0.35s, transform 0.4s cubic-bezier(0.22,1,0.36,1), box-shadow 0.35s;
  }

  .portfolio-card:hover {
    border-color: color-mix(in srgb, var(--card-color) 40%, transparent);
    transform: translateY(-8px);
    box-shadow: 0 24px 64px rgba(0,0,0,0.4), 0 0 40px color-mix(in srgb, var(--card-color) 15%, transparent);
  }

  .card-image {
    position: relative;
    aspect-ratio: 3 / 2;
    overflow: hidden;
  }

  .card-image::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0.7) 100%);
    z-index: 1;
    pointer-events: none;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.6s cubic-bezier(0.22,1,0.36,1), filter 0.4s;
  }

  .portfolio-card:hover .card-image img {
    transform: scale(1.08);
    filter: brightness(0.25);
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,0,0,0.6);
    opacity: 0;
    transition: opacity 0.4s;
    z-index: 2;
  }

  .portfolio-card:hover .card-overlay {
    opacity: 1;
  }

  .overlay-content {
    text-align: center;
    padding: 1.5rem;
    transform: translateY(20px);
    transition: transform 0.4s cubic-bezier(0.22,1,0.36,1);
  }

  .portfolio-card:hover .overlay-content {
    transform: translateY(0);
  }

  .overlay-category {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #fff;
    background: rgba(255,255,255,0.15);
    padding: 0.3rem 0.8rem;
    border-radius: 20px;
    margin-bottom: 0.75rem;
  }

  .overlay-title {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
    text-shadow: 0 2px 8px rgba(0,0,0,0.5);
  }

  .overlay-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #fff;
    font-size: 0.85rem;
    font-weight: 700;
    text-decoration: none;
    transition: gap 0.25s;
  }

  .overlay-links {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .link-btn {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s, border-color 0.2s;
  }

  .link-btn:hover {
    background: rgba(255,255,255,0.2);
    transform: scale(1.1);
    border-color: rgba(255,255,255,0.4);
  }

  .overlay-cta:hover {
    gap: 0.875rem;
  }

  .portfolio-cta {
    text-align: center;
    padding: 2.5rem;
    background: linear-gradient(135deg, rgba(6,182,212,0.06) 0%, rgba(245,158,11,0.06) 100%);
    border: 1px solid rgba(6,182,212,0.15);
    border-radius: var(--radius-lg);
  }

  .portfolio-cta p {
    color: var(--text-muted);
    font-size: 1.1rem;
    margin-bottom: 1.25rem;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--amber);
    color: #07080f;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.9rem;
    padding: 0.875rem 1.75rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
    letter-spacing: 0.01em;
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 0 28px rgba(245,158,11,0.35);
  }

  .btn-primary:hover {
    background: #fbbf24;
    transform: translateY(-2px);
    box-shadow: 0 8px 36px rgba(245,158,11,0.5);
  }

  @media (max-width: 960px) {
    .portfolio-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .portfolio-grid {
      grid-template-columns: 1fr;
    }

    .portfolio-card:hover {
      transform: none;
    }

    .card-overlay {
      opacity: 1;
      background: linear-gradient(180deg, transparent 30%, rgba(0,0,0,0.8) 100%);
    }

    .overlay-content {
      transform: none;
    }
  }
</style>