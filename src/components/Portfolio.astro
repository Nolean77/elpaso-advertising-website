---
const clients = [
  {
    name: 'Solafire',
    url: 'https://www.solafire.org',
    domain: 'solafire.org',
    industry: 'Medical · Pulmonology',
    description: 'Bilingual digital presence for a pulmonology practice serving both sides of the Border Region.',
    services: ['Social Media', 'Web Design'],
    color: '#10b981',
    initials: 'SF',
  },
  {
    name: 'El Pollo Rico',
    url: 'https://www.pollosricos.com',
    domain: 'pollosricos.com',
    industry: 'Restaurant',
    description: 'Vibrant social content and brand strategy for a beloved El Paso restaurant institution.',
    services: ['Social Media', 'Content'],
    color: '#f59e0b',
    initials: 'PR',
  },
  {
    name: 'Pulmonary Health Center',
    url: 'https://topdoctors.mx/Centro/clinica-pulmonary-health-center/',
    domain: 'topdoctors.mx',
    industry: 'Healthcare',
    description: 'Cross-border healthcare marketing driving patient awareness and building lasting trust.',
    services: ['Social Media', 'Content'],
    color: '#3b82f6',
    initials: 'PH',
  },
  {
    name: 'EP Roadrunner RV',
    url: 'https://elpasoroadrunnerrv.com',
    domain: 'elpasoroadrunnerrv.com',
    industry: 'RV Park · Hospitality',
    description: 'Online brand building and web presence for a premier El Paso RV resort destination.',
    services: ['Web Design', 'Social Media'],
    color: '#8b5cf6',
    initials: 'RR',
  },
  {
    name: 'Future Strike Bowling',
    url: null,
    domain: null,
    industry: 'Pro Shop · Retail',
    description: 'Retail brand launch and digital strategy for an El Paso bowling pro shop from the ground up.',
    services: ['Branding', 'Social Media'],
    color: '#ec4899',
    initials: 'FS',
  },
  {
    name: 'Top RV Parts',
    url: 'https://shop.toprvparts.com',
    domain: 'toprvparts.com',
    industry: 'E-commerce · Parts',
    description: 'E-commerce growth strategy and online store development for a national RV parts retailer.',
    services: ['Web Dev', 'E-commerce'],
    color: '#06b6d4',
    initials: 'TR',
  },
];
---

<section id="portfolio" class="portfolio-section">
  <div class="section-bg" aria-hidden="true"></div>

  <div class="container">
    <div class="section-header" data-reveal>
      <span class="section-label">Our Work</span>
      <h2>Trusted by Local Businesses</h2>
      <p>Proud to partner with businesses across El Paso and the Border Region — from healthcare to hospitality.</p>
    </div>

    <div class="clients-grid">
      {clients.map((client, i) => (
        <article
          class="client-card"
          style={`--c: ${client.color}; --cg: color-mix(in srgb, ${client.color} 12%, transparent);`}
          data-reveal
          data-reveal-delay={String((i % 3) + 1)}
        >
          <!-- Top bar -->
          <div class="card-top">
            <!-- Logo / Avatar -->
            <div class="client-logo" style={`background: color-mix(in srgb, ${client.color} 10%, transparent); border-color: color-mix(in srgb, ${client.color} 25%, transparent);`}>
              {client.domain ? (
                <img
                  src={`https://logo.clearbit.com/${client.domain}`}
                  alt={`${client.name} logo`}
                  width="32"
                  height="32"
                  loading="lazy"
                  onerror={`this.style.display='none'; this.nextElementSibling.style.display='flex';`}
                />
              ) : null}
              <span
                class="logo-fallback"
                style={`color: ${client.color}; display: ${client.domain ? 'none' : 'flex'};`}
              >
                {client.initials}
              </span>
            </div>

            <!-- External link or coming soon -->
            {client.url ? (
              <a
                href={client.url}
                target="_blank"
                rel="noopener noreferrer"
                class="ext-link"
                aria-label={`Visit ${client.name} website`}
              >
                <svg width="13" height="13" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <path d="M5.5 2.5H2.5a1 1 0 00-1 1v8a1 1 0 001 1h8a1 1 0 001-1v-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
                  <path d="M8.5 2.5h3v3M11.5 2.5L6 8" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            ) : (
              <span class="coming-soon">Coming Soon</span>
            )}
          </div>

          <!-- Body -->
          <p class="client-industry">{client.industry}</p>
          <h3 class="client-name">{client.name}</h3>
          <p class="client-desc">{client.description}</p>

          <!-- Tags -->
          <div class="service-tags" aria-label="Services provided">
            {client.services.map(tag => (
              <span class="tag" style={`color: ${client.color}; background: color-mix(in srgb, ${client.color} 10%, transparent); border-color: color-mix(in srgb, ${client.color} 22%, transparent);`}>
                {tag}
              </span>
            ))}
          </div>

          <!-- Bottom accent bar -->
          <div class="card-bar" aria-hidden="true"></div>
        </article>
      ))}
    </div>

    <!-- CTA -->
    <div class="portfolio-cta" data-reveal>
      <p>Ready to join them?</p>
      <a href="#contact" class="btn-primary">
        Start Your Project
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M2.5 7h9M8 3.5L11.5 7 8 10.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .portfolio-section {
    padding: var(--section-pad);
    background: var(--bg);
    position: relative;
    overflow: hidden;
  }

  .section-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 50% 50% at 20% 50%, rgba(6,182,212,0.04) 0%, transparent 70%),
      radial-gradient(ellipse 50% 50% at 80% 30%, rgba(245,158,11,0.04) 0%, transparent 70%);
    pointer-events: none;
  }

  .container {
    max-width: var(--max-w);
    margin: 0 auto;
    position: relative;
  }

  /* ── Grid ── */
  .clients-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  /* ── Card ── */
  .client-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0;
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s, transform 0.35s cubic-bezier(0.22,1,0.36,1), box-shadow 0.3s;
  }

  .client-card:hover {
    border-color: color-mix(in srgb, var(--c) 45%, transparent);
    transform: translateY(-6px);
    box-shadow:
      0 20px 56px rgba(0,0,0,0.4),
      0 0 0 1px color-mix(in srgb, var(--c) 15%, transparent);
  }

  /* Bottom color bar */
  .card-bar {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--c), color-mix(in srgb, var(--c) 20%, transparent));
    opacity: 0;
    transition: opacity 0.3s;
  }

  .client-card:hover .card-bar {
    opacity: 1;
  }

  /* ── Card Top ── */
  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1.25rem;
  }

  /* ── Logo ── */
  .client-logo {
    width: 52px; height: 52px;
    border-radius: 12px;
    border: 1px solid;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    flex-shrink: 0;
    position: relative;
  }

  .client-logo img {
    width: 36px;
    height: 36px;
    object-fit: contain;
    display: block;
  }

  .logo-fallback {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
  }

  /* ── External link ── */
  .ext-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px; height: 32px;
    border-radius: 8px;
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--border);
    color: var(--text-subtle);
    transition: color 0.2s, background 0.2s, border-color 0.2s;
    text-decoration: none;
  }

  .ext-link:hover {
    color: var(--c);
    background: var(--cg);
    border-color: color-mix(in srgb, var(--c) 35%, transparent);
  }

  /* Coming soon */
  .coming-soon {
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--text-subtle);
    border: 1px solid var(--border);
    padding: 0.22rem 0.55rem;
    border-radius: 6px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    align-self: flex-start;
  }

  /* ── Text ── */
  .client-industry {
    font-size: 0.7rem;
    color: var(--c);
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    margin-bottom: 0.35rem;
  }

  .client-name {
    font-size: 1.2rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }

  .client-desc {
    font-size: 0.875rem;
    color: var(--text-subtle);
    line-height: 1.7;
    flex: 1;
    margin-bottom: 1.25rem;
  }

  /* ── Tags ── */
  .service-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: auto;
  }

  .tag {
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.25rem 0.65rem;
    border-radius: 6px;
    border: 1px solid;
    letter-spacing: 0.03em;
  }

  /* ── Portfolio CTA ── */
  .portfolio-cta {
    margin-top: 4.5rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .portfolio-cta p {
    color: var(--text-subtle);
    font-size: 1.05rem;
    font-weight: 500;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--amber);
    color: #07080f;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.95rem;
    padding: 0.9rem 2rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
    letter-spacing: 0.01em;
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 24px rgba(245,158,11,0.3);
  }

  .btn-primary:hover {
    background: #fbbf24;
    transform: translateY(-2px);
    box-shadow: 0 10px 36px rgba(245,158,11,0.45);
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .clients-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 560px) {
    .clients-grid { grid-template-columns: 1fr; }
  }
</style>
