---
import { Image } from 'astro:assets';
import teamPhoto from '../assets/team-photo.png';

const stats = [
  { value: '100%',      label: 'Border Region Focus'  },
  { value: '3',         label: 'Core Services Offered' },
  { value: 'Bi-lingual', label: 'English & Español'   },
  { value: 'Est. 2023', label: 'El Paso Founded'       },
];
---

<section class="hero" aria-label="Hero">

  <!-- Background grid -->
  <div class="hero-grid" aria-hidden="true"></div>

  <!-- Ambient orbs -->
  <div class="orb orb-1" aria-hidden="true"></div>
  <div class="orb orb-2" aria-hidden="true"></div>
  <div class="orb orb-3" aria-hidden="true"></div>

  <div class="hero-inner">

    <!-- ── Left: Copy ── -->
    <div class="hero-copy">
      <!-- Badge -->
      <div class="hero-badge">
        <span class="badge-dot" aria-hidden="true"></span>
        Digital Solutions · El Paso & Border Region
      </div>

      <!-- Headline -->
      <h1 class="hero-title">
        Your Business,<br />
        <em class="hero-accent">Amplified</em><br />
        Online.
      </h1>

      <!-- Subheading -->
      <p class="hero-sub">
        El Paso's go-to digital marketing duo — we handle your social media, build your website, and create content that connects with your customers across the Borderland.
      </p>

      <!-- CTAs -->
      <div class="hero-actions">
        <a href="#contact" class="btn-primary">
          Get a Free Consultation
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="#services" class="btn-ghost">
          See Our Services
        </a>
      </div>

      <!-- Trust line -->
      <p class="hero-trust">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
        Trusted by local businesses in El Paso &amp; Ciudad Juárez
      </p>

      <!-- Stats -->
      <div class="hero-stats" aria-label="Key stats">
        {stats.map(s => (
          <div class="stat-item">
            <span class="stat-value">{s.value}</span>
            <span class="stat-label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- ── Right: Team Photo ── -->
    <div class="hero-visual" aria-hidden="true">
      <!-- Decorative rings -->
      <div class="visual-ring visual-ring-1"></div>
      <div class="visual-ring visual-ring-2"></div>

      <!-- Photo card (polaroid style) -->
      <div class="photo-card">
        <div class="photo-wrap">
          <Image
            src={teamPhoto}
            alt="Nolean Francisco and Carlos Terrazas, founders of El Paso Advertising Solutions"
            width={480}
            height={600}
            loading="eager"
            format="webp"
          />
        </div>
        <!-- Accent strip at bottom -->
        <div class="photo-caption">
          <span class="caption-names">Nolean &amp; Carlos</span>
          <span class="caption-tagline">El Paso Advertising Solutions</span>
        </div>
      </div>

      <!-- Floating badge: bilingual -->
      <div class="float-badge float-lang">
        <span>🇺🇸</span> English · Español <span>🇲🇽</span>
      </div>

      <!-- Floating badge: live -->
      <div class="float-badge float-active">
        <span class="live-dot"></span>
        Available Now
      </div>
    </div>

  </div>

  <!-- Scroll indicator -->
  <div class="scroll-hint" aria-hidden="true">
    <div class="scroll-track">
      <div class="scroll-thumb"></div>
    </div>
  </div>

</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 9rem 1.5rem 5rem;
    overflow: hidden;
    background: var(--bg);
  }

  /* ── Grid bg ── */
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(6,182,212,0.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(6,182,212,0.035) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: radial-gradient(ellipse 80% 70% at 50% 30%, black 20%, transparent 100%);
    -webkit-mask-image: radial-gradient(ellipse 80% 70% at 50% 30%, black 20%, transparent 100%);
  }

  /* ── Orbs ── */
  .orb {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    filter: blur(90px);
    animation: drift 14s ease-in-out infinite alternate;
  }

  .orb-1 {
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(6,182,212,0.14) 0%, transparent 70%);
    top: -5%; left: -8%;
    animation-duration: 16s;
  }

  .orb-2 {
    width: 380px; height: 380px;
    background: radial-gradient(circle, rgba(245,158,11,0.1) 0%, transparent 70%);
    bottom: 5%; right: 5%;
    animation-duration: 19s;
    animation-delay: -8s;
  }

  .orb-3 {
    width: 280px; height: 280px;
    background: radial-gradient(circle, rgba(6,182,212,0.08) 0%, transparent 70%);
    top: 50%; left: 50%;
    animation-duration: 22s;
    animation-delay: -12s;
  }

  @keyframes drift {
    0%   { transform: translate(0,0) scale(1); }
    50%  { transform: translate(24px, 18px) scale(1.05); }
    100% { transform: translate(-18px, 28px) scale(0.96); }
  }

  /* ── Inner layout ── */
  .hero-inner {
    position: relative;
    z-index: 2;
    max-width: var(--max-w);
    width: 100%;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 5rem;
    margin: 0 auto;
  }

  /* ── Copy side ── */
  .hero-copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
  }

  /* Badge */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: rgba(6,182,212,0.07);
    border: 1px solid rgba(6,182,212,0.22);
    color: var(--accent);
    padding: 0.4rem 1rem;
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    margin-bottom: 2rem;
    animation: fadeUp 0.7s cubic-bezier(0.22,1,0.36,1) both;
  }

  .badge-dot {
    width: 6px; height: 6px;
    background: var(--accent);
    border-radius: 50%;
    box-shadow: 0 0 8px var(--accent);
    animation: pulse 2s ease infinite;
    flex-shrink: 0;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.5; transform: scale(1.5); }
  }

  /* Headline */
  .hero-title {
    font-size: clamp(2.8rem, 5.5vw, 4.5rem);
    font-weight: 800;
    color: #fff;
    line-height: 1.05;
    margin-bottom: 1.75rem;
    animation: fadeUp 0.7s 0.1s cubic-bezier(0.22,1,0.36,1) both;
  }

  .hero-accent {
    display: inline-block;
    font-style: normal;
    background: linear-gradient(120deg, #06b6d4 0%, #f59e0b 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    filter: drop-shadow(0 0 28px rgba(6,182,212,0.4));
    position: relative;
  }

  /* Underline decoration */
  .hero-accent::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -4px;
    width: 100%;
    height: 3px;
    background: linear-gradient(90deg, #06b6d4, #f59e0b, transparent);
    border-radius: 2px;
    animation: slideIn 0.8s 0.5s ease both;
  }

  @keyframes slideIn {
    from { width: 0; opacity: 0; }
    to   { width: 100%; opacity: 1; }
  }

  /* Subhead */
  .hero-sub {
    font-size: clamp(0.95rem, 1.8vw, 1.1rem);
    color: var(--text-muted);
    max-width: 500px;
    line-height: 1.8;
    margin-bottom: 2.25rem;
    animation: fadeUp 0.7s 0.2s cubic-bezier(0.22,1,0.36,1) both;
  }

  /* CTAs */
  .hero-actions {
    display: flex;
    gap: 0.875rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
    animation: fadeUp 0.7s 0.3s cubic-bezier(0.22,1,0.36,1) both;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--amber);
    color: #07080f;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.9rem;
    padding: 0.875rem 1.75rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
    letter-spacing: 0.01em;
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 0 28px rgba(245,158,11,0.35);
  }

  .btn-primary:hover {
    background: #fbbf24;
    transform: translateY(-2px);
    box-shadow: 0 8px 36px rgba(245,158,11,0.5);
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.11);
    color: var(--text);
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.9rem;
    padding: 0.875rem 1.75rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
    letter-spacing: 0.01em;
    transition: background 0.2s, border-color 0.2s, transform 0.2s;
  }

  .btn-ghost:hover {
    background: rgba(255,255,255,0.09);
    border-color: rgba(255,255,255,0.22);
    transform: translateY(-2px);
  }

  /* Trust line */
  .hero-trust {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-subtle);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    margin-bottom: 2.75rem;
    animation: fadeUp 0.7s 0.35s cubic-bezier(0.22,1,0.36,1) both;
  }

  .hero-trust svg {
    color: var(--accent);
    flex-shrink: 0;
  }

  /* Stats */
  .hero-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    width: 100%;
    animation: fadeUp 0.7s 0.45s cubic-bezier(0.22,1,0.36,1) both;
  }

  .stat-item {
    background: var(--bg-card);
    padding: 1.25rem 0.875rem;
    text-align: center;
    transition: background 0.2s;
    cursor: default;
  }

  .stat-item:hover {
    background: rgba(6,182,212,0.07);
  }

  .stat-value {
    display: block;
    font-family: var(--font-display);
    font-size: 1.65rem;
    font-weight: 800;
    color: var(--accent);
    line-height: 1;
    margin-bottom: 0.4rem;
    letter-spacing: -0.03em;
  }

  .stat-label {
    display: block;
    font-size: 0.67rem;
    color: var(--text-subtle);
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    line-height: 1.3;
  }

  /* ── Visual side ── */
  .hero-visual {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: fadeIn 1s 0.4s ease both;
  }

  /* Decorative rings */
  .visual-ring {
    position: absolute;
    border-radius: 50%;
    border: 1px solid;
    pointer-events: none;
  }

  .visual-ring-1 {
    width: 480px; height: 480px;
    border-color: rgba(6,182,212,0.1);
    animation: ringRotate 30s linear infinite;
  }

  .visual-ring-2 {
    width: 360px; height: 360px;
    border-color: rgba(245,158,11,0.08);
    animation: ringRotate 20s linear infinite reverse;
  }

  @keyframes ringRotate {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  /* Photo card */
  .photo-card {
    position: relative;
    z-index: 2;
    background: #fff;
    border-radius: 4px;
    padding: 10px 10px 48px 10px;
    box-shadow:
      0 40px 100px rgba(0,0,0,0.55),
      0 0 0 1px rgba(255,255,255,0.08),
      inset 0 0 0 1px rgba(0,0,0,0.05);
    transform: rotate(1.5deg);
    transition: transform 0.4s cubic-bezier(0.22,1,0.36,1), box-shadow 0.4s;
    max-width: 340px;
  }

  .photo-card:hover {
    transform: rotate(0deg) translateY(-6px) scale(1.01);
    box-shadow:
      0 60px 120px rgba(0,0,0,0.6),
      0 0 0 1px rgba(255,255,255,0.1),
      0 0 60px rgba(6,182,212,0.12);
  }

  .photo-wrap {
    overflow: hidden;
    border-radius: 2px;
    line-height: 0;
  }

  .photo-wrap img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    object-position: center top;
  }

  /* Caption (polaroid text area) */
  .photo-caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 48px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2px;
    background: #fff;
    border-radius: 0 0 4px 4px;
  }

  .caption-names {
    font-family: 'Courier New', monospace;
    font-size: 0.8rem;
    font-weight: 700;
    color: #1a1a2e;
    letter-spacing: 0.05em;
  }

  .caption-tagline {
    font-family: 'Courier New', monospace;
    font-size: 0.65rem;
    color: #888;
    letter-spacing: 0.04em;
  }

  /* Floating badges */
  .float-badge {
    position: absolute;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 50px;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-muted);
    padding: 0.45rem 1rem;
    white-space: nowrap;
    backdrop-filter: blur(12px);
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
    z-index: 3;
  }

  .float-lang {
    bottom: -10px;
    right: -20px;
    animation: floatA 6s ease-in-out infinite;
  }

  .float-active {
    top: 20px;
    left: -25px;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border-color: rgba(16,185,129,0.3);
    animation: floatB 7s ease-in-out infinite;
  }

  .live-dot {
    width: 7px; height: 7px;
    background: #10b981;
    border-radius: 50%;
    box-shadow: 0 0 8px #10b981;
    animation: pulse 2s ease infinite;
  }

  @keyframes floatA {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(-8px); }
  }

  @keyframes floatB {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(6px); }
  }

  /* ── Scroll hint ── */
  .scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    animation: fadeIn 1s 1.2s ease both;
  }

  .scroll-track {
    width: 6px;
    height: 30px;
    border: 1.5px solid rgba(6,182,212,0.25);
    border-radius: 3px;
    position: relative;
    overflow: hidden;
  }

  .scroll-thumb {
    position: absolute;
    top: 4px;
    left: 50%;
    transform: translateX(-50%);
    width: 2px;
    height: 8px;
    background: var(--accent);
    border-radius: 1px;
    animation: scrollDown 1.6s ease infinite;
  }

  @keyframes scrollDown {
    0%   { top: 4px;  opacity: 1; }
    100% { top: 18px; opacity: 0; }
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(22px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .hero-inner {
      gap: 3rem;
    }

    .photo-card { max-width: 290px; }

    .visual-ring-1 { width: 380px; height: 380px; }
    .visual-ring-2 { width: 280px; height: 280px; }
  }

  @media (max-width: 768px) {
    .hero {
      padding: 8rem 1.25rem 5rem;
    }

    .hero-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
      text-align: center;
    }

    .hero-copy {
      align-items: center;
      order: 2;
    }

    .hero-visual {
      order: 1;
    }

    .hero-sub {
      margin-left: auto;
      margin-right: auto;
    }

    .hero-actions {
      justify-content: center;
    }

    .hero-trust {
      justify-content: center;
    }

    .hero-stats {
      grid-template-columns: repeat(2, 1fr);
    }

    .photo-card {
      max-width: 260px;
      transform: rotate(0deg);
    }

    .visual-ring-1 { width: 300px; height: 300px; }
    .visual-ring-2 { width: 220px; height: 220px; }

    .float-lang { bottom: -16px; right: -8px; font-size: 0.68rem; }
    .float-active { top: 8px; left: -8px; font-size: 0.68rem; }
  }

  @media (max-width: 480px) {
    .btn-primary, .btn-ghost {
      width: 100%;
      justify-content: center;
    }
    .hero-actions { flex-direction: column; }
    .scroll-hint { display: none; }
  }
</style>
