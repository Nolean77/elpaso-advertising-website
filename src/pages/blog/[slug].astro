---
import { getCollection, render } from 'astro:content';
import BlogPostLayout from '../../layouts/BlogPostLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const {
  title,
  description,
  pubDate,
  author,
  authorTitle,
  featuredImage,
  featuredImageAlt,
  tags,
  language,
} = post.data;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const langLabel    = language === 'es' ? 'Español' : 'English';
const canonicalUrl = `https://elpasoadvertisingsolutions.com/blog/${post.id}`;
---

<BlogPostLayout
  title={`${title} — EP Advertising Solutions Blog`}
  description={description}
  ogImage={featuredImage ?? '/og-image.png'}
  canonicalUrl={canonicalUrl}
>
  <article class="post-article">

    <!-- Featured Image -->
    {featuredImage && (
      <div class="post-hero-image">
        <img
          src={featuredImage}
          alt={featuredImageAlt ?? title}
          loading="eager"
          decoding="async"
          width="1200"
          height="630"
        />
      </div>
    )}

    <div class="post-container">

      <!-- Back link -->
      <nav class="post-breadcrumb" aria-label="Breadcrumb">
        <a href="/blog" class="back-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M19 12H5M12 5l-7 7 7 7"/>
          </svg>
          Back to Blog
        </a>
      </nav>

      <!-- Post Header -->
      <header class="post-header">
        <!-- Tags -->
        {tags.length > 0 && (
          <div class="post-tags">
            {tags.map(tag => (
              <a href={`/blog/tag/${tag}`} class="post-tag">{tag}</a>
            ))}
            <span class={`lang-pill lang-${language}`}>{langLabel}</span>
          </div>
        )}

        <h1 class="post-title">{title}</h1>
        <p class="post-description">{description}</p>

        <!-- Meta row -->
        <div class="post-meta">
          <div class="meta-author">
            <div class="author-avatar" aria-hidden="true">{author.charAt(0)}</div>
            <div>
              <span class="author-name">{author}</span>
              {authorTitle && <span class="author-role">{authorTitle}</span>}
            </div>
          </div>
          <time class="meta-date" datetime={pubDate.toISOString()}>
            {formattedDate}
          </time>
        </div>
      </header>

      <!-- Post Body -->
      <div class="post-body">
        <Content />
      </div>

      <!-- Post Footer -->
      <footer class="post-footer">
        <div class="post-footer-tags">
          {tags.length > 0 && (
            <>
              <span class="footer-tags-label">Topics:</span>
              {tags.map(tag => (
                <a href={`/blog/tag/${tag}`} class="post-tag">{tag}</a>
              ))}
            </>
          )}
        </div>
        <a href="/blog" class="back-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M19 12H5M12 5l-7 7 7 7"/>
          </svg>
          Back to Blog
        </a>
      </footer>

    </div>
  </article>
</BlogPostLayout>

<style>
  /* ── Featured image ── */
  .post-hero-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .post-hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── Container ── */
  .post-container {
    max-width: 760px;
    margin: 0 auto;
    padding: 2.5rem 1.5rem 5rem;
  }

  /* ── Breadcrumb ── */
  .post-breadcrumb { margin-bottom: 2rem; }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-muted);
    transition: color 0.2s, gap 0.2s;
    text-decoration: none;
  }

  .back-link:hover { color: var(--accent); gap: 0.6rem; }

  /* ── Post header ── */
  .post-header {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
  }

  /* Tags row */
  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .post-tag {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--accent);
    background: rgba(108, 99, 255, 0.1);
    border: 1px solid rgba(108, 99, 255, 0.2);
    padding: 0.22rem 0.65rem;
    border-radius: 100px;
    text-decoration: none;
    transition: background 0.2s;
  }

  .post-tag:hover { background: rgba(108, 99, 255, 0.22); }

  .lang-pill {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.22rem 0.65rem;
    border-radius: 100px;
  }

  .lang-en { background: rgba(108, 99, 255, 0.2); color: #a9a3ff; }
  .lang-es { background: rgba(255, 101, 132, 0.15); color: #ff6584; }

  /* Title */
  .post-title {
    font-family: var(--font-display);
    font-size: clamp(1.9rem, 4.5vw, 2.75rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.03em;
    color: var(--text);
    margin-bottom: 1rem;
  }

  /* Description */
  .post-description {
    font-size: 1.1rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  /* Meta row */
  .post-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .meta-author {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .author-avatar {
    width: 38px; height: 38px;
    border-radius: 50%;
    background: rgba(108, 99, 255, 0.18);
    border: 1.5px solid rgba(108, 99, 255, 0.35);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--accent);
    flex-shrink: 0;
  }

  .author-name {
    display: block;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text);
  }

  .author-role {
    display: block;
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  .meta-date {
    font-size: 0.82rem;
    color: var(--text-muted);
  }

  /* ── Post body ── */
  .post-body {
    font-size: 1rem;
    line-height: 1.8;
    color: #d8d8f0;
  }

  .post-body :global(h2) {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--text);
    margin: 2.5rem 0 1rem;
    line-height: 1.2;
  }

  .post-body :global(h3) {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
    margin: 2rem 0 0.75rem;
  }

  .post-body :global(p) {
    margin-bottom: 1.4rem;
  }

  .post-body :global(ul),
  .post-body :global(ol) {
    margin: 0 0 1.4rem 1.4rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .post-body :global(li) { line-height: 1.7; }

  .post-body :global(strong) {
    font-weight: 700;
    color: var(--text);
  }

  .post-body :global(em) { color: #b8b8d8; }

  .post-body :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s;
  }

  .post-body :global(a:hover) { color: #a9a3ff; }

  .post-body :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding: 0.75rem 1.25rem;
    margin: 1.75rem 0;
    background: rgba(108, 99, 255, 0.07);
    border-radius: 0 8px 8px 0;
    color: var(--text-muted);
    font-style: italic;
  }

  .post-body :global(code) {
    font-family: 'Fira Code', 'Cascadia Code', monospace;
    font-size: 0.88em;
    background: rgba(108, 99, 255, 0.12);
    color: #c4b5fd;
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }

  .post-body :global(pre) {
    background: #0d0d1a;
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    margin: 1.75rem 0;
  }

  .post-body :global(pre code) {
    background: none;
    padding: 0;
    font-size: 0.875rem;
    color: #c4b5fd;
  }

  .post-body :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2.5rem 0;
  }

  .post-body :global(img) {
    border-radius: 10px;
    margin: 1.5rem 0;
    width: 100%;
    height: auto;
  }

  /* ── Post footer ── */
  .post-footer {
    margin-top: 3rem;
    padding-top: 1.75rem;
    border-top: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .post-footer-tags {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .footer-tags-label {
    font-size: 0.82rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  @media (max-width: 600px) {
    .post-container { padding: 2rem 1.25rem 3rem; }
    .post-meta { flex-direction: column; align-items: flex-start; }
    .post-footer { flex-direction: column-reverse; align-items: flex-start; }
  }
</style>
