  <!-- ===================================
       JAVASCRIPT — is:inline is REQUIRED.
       Without it, Astro bundles this as an
       ES module, which breaks GSAP globals
       and the onclick handlers above.
  =================================== -->
  <script is:inline>
    // ===========================
    // LOADER
    // ===========================
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let progress = 0;
    const loaderBar  = document.getElementById('loader-bar');
    const loaderPct  = document.getElementById('loader-pct');
    const loaderEl   = document.getElementById('loader');
    const loaderLogo = document.querySelector('.loader-logo');
    const form = document.getElementById('contact-form');

    gsap.to(loaderLogo, { opacity: 1, duration: 0.5, delay: 0.2 });

    const loaderInterval = setInterval(() => {
      progress = Math.min(100, progress + Math.random() * 15);
      if (progress >= 100) {
        progress = 100;
        clearInterval(loaderInterval);
        loaderBar.style.width = '100%';
        loaderPct.textContent = '100%';
        setTimeout(() => {
          gsap.to(loaderEl, {
            yPercent: -100,
            duration: 0.8,
            ease: 'power3.inOut',
            onComplete: () => {
              loaderEl.style.display = 'none';
              initAnimations();
            }
          });
        }, 300);
      } else {
        loaderBar.style.width = progress + '%';
        loaderPct.textContent = Math.floor(progress) + '%';
      }
    }, 80);

    // ===========================
    // LENIS SMOOTH SCROLL
    // ===========================
    const lenis = new Lenis({
      duration: 1.2,
      easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      smooth: !prefersReducedMotion,
    });

    lenis.on('scroll', ScrollTrigger.update);
    gsap.ticker.add((time) => lenis.raf(time * 1000));
    gsap.ticker.lagSmoothing(0);

    // ===========================
    // CURSOR
    // ===========================
    const dotWrap  = document.getElementById('cursor-dot-wrap');
    const ringWrap = document.getElementById('cursor-ring-wrap');

    if (window.matchMedia('(pointer: fine)').matches) {
      document.addEventListener('mousemove', (e) => {
        gsap.to(dotWrap,  { x: e.clientX, y: e.clientY, duration: 0.05 });
        gsap.to(ringWrap, { x: e.clientX, y: e.clientY, duration: 0.25, ease: 'power2.out' });
      });
    }

    // ===========================
    // SCROLL PROGRESS BAR
    // ===========================
    const scrollBar = document.getElementById('scroll-progress');
    window.addEventListener('scroll', () => {
      const pct = window.scrollY / (document.body.scrollHeight - window.innerHeight);
      scrollBar.style.transform = `scaleX(${pct})`;
    }, { passive: true });

    // ===========================
    // NAV SCROLL STATE + BACK TO TOP
    // ===========================
    const nav = document.getElementById('nav');
    const btt = document.getElementById('back-to-top');

    window.addEventListener('scroll', () => {
      nav.classList.toggle('scrolled', window.scrollY > 40);
      btt.classList.toggle('visible', window.scrollY > 400);
    }, { passive: true });

    btt.addEventListener('click', () => lenis.scrollTo(0));

    // ===========================
    // MOBILE NAV
    // ===========================
    const navToggle = document.getElementById('nav-toggle');
    const navMobile = document.getElementById('nav-mobile');
    const navMobileOverlay = document.getElementById('nav-mobile-overlay');

    const closeNav = () => {
      navToggle.classList.remove('active');
      navMobile.classList.remove('open');
      navMobileOverlay.classList.remove('active');
      navToggle.setAttribute('aria-expanded', 'false');
      navMobile.setAttribute('aria-hidden', 'true');
      navMobileOverlay.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    };

    const openNav = () => {
      navToggle.classList.add('active');
      navMobile.classList.add('open');
      navMobileOverlay.classList.add('active');
      navToggle.setAttribute('aria-expanded', 'true');
      navMobile.setAttribute('aria-hidden', 'false');
      navMobileOverlay.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    };

    navToggle.addEventListener('click', () => {
      const isOpen = navMobile.classList.contains('open');
      isOpen ? closeNav() : openNav();
    });

    navMobileOverlay.addEventListener('click', closeNav);

    document.querySelectorAll('.mobile-link').forEach(l => {
      l.addEventListener('click', closeNav);
    });

    // Close nav on escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && navMobile.classList.contains('open')) {
        closeNav();
      }
    });

    // Analytics-ready helper. No-op until GA/GTM is configured.
    function trackEvent(eventName, params = {}) {
      if (typeof window.gtag === 'function') {
        window.gtag('event', eventName, params);
      }
    }

    // ===========================
    // SMOOTH ANCHOR SCROLLING
    // ===========================
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', (e) => {
        const id = anchor.getAttribute('href').slice(1);
        if (!id) {
          e.preventDefault();
          lenis.scrollTo(0, { duration: prefersReducedMotion ? 0 : 1.2 });
          return;
        }
        const target = document.getElementById(id);
        if (target) {
          e.preventDefault();
          lenis.scrollTo(target, { offset: -80, duration: prefersReducedMotion ? 0 : 1.2 });
        }
      });
    });

    form?.addEventListener('submit', handleFormSubmit);

    // ===========================
    // ANIMATIONS (after loader)
    // ===========================
    function initAnimations() {
      gsap.registerPlugin(ScrollTrigger, TextPlugin);

      // Hero word reveal
      gsap.to('.hero-title .word-inner', {
        y: 0, duration: 0.9, stagger: 0.12, ease: 'power3.out', delay: 0.1,
      });

      // Hero supporting elements
      gsap.to(['#hero-eyebrow', '#hero-sub', '#hero-actions', '#hero-stats'], {
        opacity: 1, y: 0, duration: 0.8, stagger: 0.15, ease: 'power2.out', delay: 0.5,
      });

      // Counters — use Intersection Observer to start animation when scrolled into view
      const statsSection = document.getElementById('hero-stats');
      let countersAnimated = false;

      const counterObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting && !countersAnimated) {
            countersAnimated = true;
            document.querySelectorAll('.count').forEach((el, index) => {
              const target = parseInt(el.dataset.target);
              gsap.to({ val: 0 }, {
                val: target,
                duration: 2.5,
                ease: 'cubic.inOut',
                delay: index * 0.1,
                onUpdate: function () {
                  el.textContent = Math.round(this.targets()[0].val);
                }
              });
            });
            counterObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.3 });

      if (statsSection) {
        counterObserver.observe(statsSection);
      }

      // Generic reveals
      gsap.utils.toArray('.reveal').forEach((el, i) => {
        gsap.to(el, {
          opacity: 1, y: 0, duration: 0.8, ease: 'power2.out',
          scrollTrigger: { trigger: el, start: 'top 88%', toggleActions: 'play none none none' },
          delay: (i % 4) * 0.08,
        });
      });

      gsap.utils.toArray('.reveal-left').forEach(el => {
        gsap.to(el, {
          opacity: 1, x: 0, duration: 0.9, ease: 'power2.out',
          scrollTrigger: { trigger: el, start: 'top 88%', toggleActions: 'play none none none' },
        });
      });

      gsap.utils.toArray('.reveal-right').forEach(el => {
        gsap.to(el, {
          opacity: 1, x: 0, duration: 0.9, ease: 'power2.out',
          scrollTrigger: { trigger: el, start: 'top 88%', toggleActions: 'play none none none' },
        });
      });

      // Service cards stagger
      gsap.utils.toArray('.service-card').forEach((card, i) => {
        card.style.opacity = 0;
        card.style.transform = 'translateY(40px)';
        gsap.to(card, {
          opacity: 1, y: 0, duration: 0.7, ease: 'power2.out',
          scrollTrigger: { trigger: '#services .services-grid', start: 'top 80%' },
          delay: i * 0.15,
        });
      });

      // Portfolio cards stagger
      gsap.utils.toArray('.portfolio-card').forEach((card, i) => {
        card.style.opacity = 0;
        card.style.transform = 'translateY(30px)';
        gsap.to(card, {
          opacity: card.classList.contains('coming-soon') ? 0.55 : 1,
          y: 0, duration: 0.65, ease: 'power2.out',
          scrollTrigger: { trigger: '#portfolio .portfolio-grid', start: 'top 80%' },
          delay: i * 0.1,
        });
      });

      // Reach location cards stagger
      gsap.utils.toArray('.reach-location').forEach((loc, i) => {
        loc.style.opacity = 0;
        loc.style.transform = 'translateY(20px)';
        gsap.to(loc, {
          opacity: 1, y: 0, duration: 0.5, ease: 'power2.out',
          scrollTrigger: { trigger: '#reach .reach-map', start: 'top 80%' },
          delay: i * 0.1,
        });
      });

      // Process steps
      gsap.utils.toArray('.process-step').forEach((step, i) => {
        step.style.opacity = 0;
        step.style.transform = 'translateY(30px)';
        gsap.to(step, {
          opacity: 1, y: 0, duration: 0.65, ease: 'power2.out',
          scrollTrigger: { trigger: '#process .process-steps', start: 'top 80%' },
          delay: i * 0.12,
        });
      });

      // Parallax orbs
      gsap.to('.orb-1', { y: -120, scrollTrigger: { trigger: 'body', start: 'top top', end: 'bottom bottom', scrub: 2 } });
      gsap.to('.orb-2', { y: -80,  scrollTrigger: { trigger: 'body', start: 'top top', end: 'bottom bottom', scrub: 3 } });

      // Nav active state on scroll
      document.querySelectorAll('section[id]').forEach(section => {
        ScrollTrigger.create({
          trigger: section, start: 'top 60%', end: 'bottom 60%',
          onEnter:     () => setActiveNav(section.id),
          onEnterBack: () => setActiveNav(section.id),
        });
      });
    }

    function setActiveNav(id) {
      document.querySelectorAll('.nav-links a').forEach(a => {
        a.style.color = a.getAttribute('href') === '#' + id ? 'var(--text)' : '';
      });
    }

    // ===========================
    // FORM SUBMIT
    // Replace the fake await below with the
    // real Formspree fetch (see DEPLOY.md)
    // ===========================
    async function handleFormSubmit(e) {
      e.preventDefault();
      const name    = document.getElementById('f-name').value.trim();
      const email   = document.getElementById('f-email').value.trim();
      const message = document.getElementById('f-message').value.trim();
      const honeypot = document.getElementById('f-gotcha').value.trim();
      const errorEl = document.getElementById('form-error');
      const requiredFields = [['f-name', name], ['f-email', email], ['f-message', message]];

      errorEl.style.display = 'none';
      errorEl.textContent = '';

      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

      requiredFields.forEach(([id]) => {
        const input = document.getElementById(id);
        input.removeAttribute('aria-invalid');
      });

      if (honeypot) {
        trackEvent('form_submit_blocked', { source: 'contact_form', reason: 'honeypot' });
        return;
      }

      if (!name || !email || !message) {
        requiredFields.forEach(([id, val]) => {
          if (!val) {
            const el = document.getElementById(id);
            gsap.fromTo(el, { x: -8 }, {
              x: 0, duration: 0.4, ease: 'elastic.out(1, 0.3)',
              keyframes: [{ x: -8 }, { x: 8 }, { x: -5 }, { x: 5 }, { x: 0 }]
            });
            el.style.borderColor = 'var(--accent-2)';
            el.setAttribute('aria-invalid', 'true');
            setTimeout(() => el.style.borderColor = '', 2000);
          }
        });
        errorEl.textContent = 'Please fill out the required fields before sending.';
        errorEl.style.display = 'block';
        trackEvent('form_error', { type: 'required_fields' });
        return;
      }

      if (!emailRegex.test(email)) {
        const emailInput = document.getElementById('f-email');
        emailInput.style.borderColor = 'var(--accent-2)';
        emailInput.setAttribute('aria-invalid', 'true');
        setTimeout(() => emailInput.style.borderColor = '', 2000);
        errorEl.textContent = 'Please enter a valid email address.';
        errorEl.style.display = 'block';
        trackEvent('form_error', { type: 'invalid_email' });
        return;
      }

      const btn = document.getElementById('form-submit');
      btn.textContent = 'Sending…';
      btn.disabled = true;
      let timeoutId;

      try {
        const controller = new AbortController();
        timeoutId = setTimeout(() => controller.abort(), 10000);
        const response = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          signal: controller.signal,
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json',
          },
          body: JSON.stringify({
            access_key: 'f0a698f3-4325-4261-b60b-1d94dfb8ab1f',
            name:    document.getElementById('f-name').value,
            email:   document.getElementById('f-email').value,
            phone:   document.getElementById('f-phone').value,
            country: document.getElementById('f-country').value,
            service: document.getElementById('f-service').value,
            message: document.getElementById('f-message').value,
          }),
        });
        if (!response.ok) throw new Error('Form submission error');
        trackEvent('form_submit_success', { source: 'contact_form' });
        form?.reset();

        gsap.to('#form-fields', {
          opacity: 0, y: -20, duration: 0.4,
          onComplete: () => {
            document.getElementById('form-fields').style.display = 'none';
            const success = document.getElementById('form-success');
            success.classList.add('show');
            gsap.from(success, { opacity: 0, y: 20, duration: 0.5 });
          }
        });
      } catch (err) {
        const timedOut = err && err.name === 'AbortError';
        trackEvent('form_submit_error', {
          source: 'contact_form',
          error_type: timedOut ? 'timeout' : 'server_or_network'
        });
        btn.textContent = 'Could not send. Please try again or email us directly.';
        btn.disabled = false;
        btn.style.background = 'var(--accent-2)';
        errorEl.textContent = timedOut
          ? 'The request timed out. Please try again in a moment.'
          : 'Network issue or server error. Please try again in a moment.';
        errorEl.style.display = 'block';
        setTimeout(() => {
          btn.textContent = 'Send Message →';
          btn.style.background = '';
        }, 3000);
      } finally {
        clearTimeout(timeoutId);
      }
    }
  </script>
