---
interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
}

const {
  title,
  description,
  canonicalUrl = Astro.url.href,
  ogImage = '/og-image.png',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Open Graph -->
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url"         content={canonicalUrl} />
  <meta property="og:type"        content="website" />
  <meta property="og:image"       content={ogImage} />

  <!-- Twitter Card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImage} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon"    href="/apple-touch-icon.png" />
  <link rel="manifest"            href="/site.webmanifest" />

  <!-- Fonts — preconnect first, then stylesheet -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,600;12..96,700;12..96,800&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
    rel="stylesheet"
  />

  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-GBB36CD3G6"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-GBB36CD3G6');
  </script>

  <!-- GSAP + plugins (CDN, loaded before body so GSAP globals exist for inline scripts) -->
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/TextPlugin.min.js"></script>

  <!-- Lenis smooth scroll -->
  <script is:inline src="https://cdn.jsdelivr.net/npm/@studio-freight/lenis@1.0.42/dist/lenis.min.js"></script>

  <slot name="head" />

  <style is:global>
    /* =====================================================
       DESIGN TOKENS
    ===================================================== */
    :root {
      --bg:            #07080f;
      --bg-card:       #0d0f1e;
      --bg-elevated:   #111327;
      --border:        rgba(255,255,255,0.07);
      --accent:        #06b6d4;
      --amber:         #f59e0b;
      --emerald:       #10b981;
      --text:          #e2e8f0;
      --text-muted:    #94a3b8;
      --text-subtle:   #566070;
      --font-display:  'Bricolage Grotesque', sans-serif;
      --font-body:     'Plus Jakarta Sans', sans-serif;
      --max-w:         1200px;
      --radius:        12px;
      --radius-sm:     8px;
      --radius-lg:     16px;
      --nav-height:    72px;
      --section-pad:   clamp(4rem, 8vw, 7rem) clamp(1.25rem, 4vw, 3rem);
    }

    /* =====================================================
       RESET & BASE
    ===================================================== */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: auto; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font-body);
      font-size: 16px;
      line-height: 1.65;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }

    a    { color: inherit; text-decoration: none; }
    img  { max-width: 100%; display: block; }
    ul   { list-style: none; }
    button { cursor: pointer; border: none; background: none; font-family: inherit; }

    /* =====================================================
       SCROLLBAR
    ===================================================== */
    ::-webkit-scrollbar       { width: 5px; }
    ::-webkit-scrollbar-track { background: var(--bg); }
    ::-webkit-scrollbar-thumb { background: var(--accent); border-radius: 3px; }

    /* =====================================================
       SCROLL PROGRESS BAR
    ===================================================== */
    #scroll-progress {
      position: fixed;
      top: 0; left: 0;
      height: 2px;
      background: linear-gradient(90deg, var(--accent), var(--amber));
      z-index: 9997;
      transform-origin: left;
      transform: scaleX(0);
      width: 100%;
      pointer-events: none;
    }

    /* =====================================================
       BACK TO TOP
    ===================================================== */
    #back-to-top {
      position: fixed;
      bottom: 2rem; right: 2rem;
      width: 44px; height: 44px;
      background: var(--accent);
      color: #07080f;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.1rem;
      font-weight: 700;
      cursor: pointer;
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.3s, transform 0.3s, background 0.2s;
      z-index: 100;
      box-shadow: 0 4px 20px rgba(6,182,212,0.35);
    }

    #back-to-top.visible { opacity: 1; transform: translateY(0); }
    #back-to-top:hover   { background: #22d3ee; }

    /* =====================================================
       SECTION HEADER (shared across sections)
    ===================================================== */
    .section-header {
      text-align: center;
      max-width: 640px;
      margin: 0 auto 4rem;
    }

    .section-label {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 0.875rem;
    }

    .section-label::before {
      content: '';
      display: block;
      width: 18px; height: 2px;
      background: var(--accent);
      flex-shrink: 0;
    }

    .section-header h2 {
      font-family: var(--font-display);
      font-size: clamp(1.9rem, 4vw, 3rem);
      font-weight: 800;
      color: #fff;
      line-height: 1.1;
      letter-spacing: -0.025em;
      margin-bottom: 1rem;
    }

    .section-header p {
      color: var(--text-muted);
      font-size: 1.05rem;
      line-height: 1.75;
    }

    /* =====================================================
       REVEAL ANIMATIONS (applied by JS after load)
    ===================================================== */
    [data-reveal] {
      opacity: 0;
      transform: translateY(32px);
      transition: opacity 0.65s ease, transform 0.65s cubic-bezier(0.22,1,0.36,1);
    }

    [data-reveal].visible {
      opacity: 1;
      transform: none;
    }

    /* =====================================================
       FLOATING WHATSAPP BUTTON
    ===================================================== */
    .whatsapp-float {
      position: fixed;
      bottom: 2rem;
      right: 5.5rem;
      width: 52px; height: 52px;
      background: #25D366;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 4px 20px rgba(37,211,102,0.45);
      z-index: 100;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      animation: waPulse 2.5s ease-in-out infinite;
    }

    .whatsapp-float:hover {
      transform: translateY(-3px) scale(1.06);
      box-shadow: 0 8px 30px rgba(37,211,102,0.65);
      animation: none;
    }

    .whatsapp-float svg { width: 28px; height: 28px; fill: #fff; }

    @keyframes waPulse {
      0%,100% { box-shadow: 0 4px 20px rgba(37,211,102,0.4); }
      50%      { box-shadow: 0 4px 32px rgba(37,211,102,0.75); }
    }

    /* =====================================================
       REDUCED MOTION
    ===================================================== */
    @media (prefers-reduced-motion: reduce) {
      [data-reveal]         { opacity: 1 !important; transform: none !important; transition: none !important; }
      .whatsapp-float       { animation: none !important; }
      *                     { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; }
    }
  </style>
</head>
<body>

  <!-- Scroll progress indicator -->
  <div id="scroll-progress" aria-hidden="true"></div>

  <slot />

  <!-- Back to top -->
  <button id="back-to-top" aria-label="Back to top">↑</button>

  <!-- Floating WhatsApp button -->
  <a
    href="https://wa.me/+526563882009"
    target="_blank"
    rel="noopener noreferrer"
    class="whatsapp-float"
    aria-label="Chat with us on WhatsApp"
  >
    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
  </a>

  <script is:inline>
    // ── Lenis smooth scroll ──
    const lenis = new Lenis({
      duration: 1.2,
      easing: t => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
    });

    (function raf(time) {
      lenis.raf(time);
      requestAnimationFrame(raf);
    })(0);

    lenis.on('scroll', ScrollTrigger.update);
    gsap.ticker.add(time => lenis.raf(time * 1000));
    gsap.ticker.lagSmoothing(0);

    // ── Scroll progress bar ──
    const progressBar = document.getElementById('scroll-progress');
    window.addEventListener('scroll', () => {
      const pct = window.scrollY / (document.body.scrollHeight - window.innerHeight);
      progressBar.style.transform = `scaleX(${pct})`;
    }, { passive: true });

    // ── Back to top ──
    const btt = document.getElementById('back-to-top');
    window.addEventListener('scroll', () => {
      btt.classList.toggle('visible', window.scrollY > 400);
    }, { passive: true });
    btt.addEventListener('click', () => lenis.scrollTo(0));

    // ── Smooth anchor links ──
    document.querySelectorAll('a[href^="#"]').forEach(a => {
      a.addEventListener('click', e => {
        const id = a.getAttribute('href').slice(1);
        if (!id) return;
        const target = document.getElementById(id);
        if (target) { e.preventDefault(); lenis.scrollTo(target, { offset: -80, duration: 1.2 }); }
      });
    });

    // ── Reveal on scroll (IntersectionObserver — no GSAP dep needed) ──
    const revealObs = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const delay = entry.target.dataset.revealDelay;
          if (delay) entry.target.style.transitionDelay = `${Number(delay) * 0.1}s`;
          entry.target.classList.add('visible');
          revealObs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.12 });

    document.querySelectorAll('[data-reveal]').forEach(el => revealObs.observe(el));
  </script>
</body>
</html>
